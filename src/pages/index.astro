---
import BaseLayout from '../layouts/RootLayout.astro'
import './index.css'
---

<BaseLayout
  title="Andrei Furdui — Product Engineer"
  description="Full-stack product engineer and founder. I ship products fast."
>
  <div class="home_page">
    <div class="home_page-rails">
      <!-- ===================== HERO ===================== -->
      <section class="home_page-section" data-region="hero">
        <div class="l_stack" data-gap="8">
          <div class="l_cluster" data-justify="between" data-gap="4">
            <span class="home_page-hero_tag">Product Engineer</span>
          </div>

          <div class="l_stack" data-gap="5">
            <h1 class="home_page-title">Andrei Furdui</h1>
            <p class="home_page-hero_lead">I ship products fast.</p>
          </div>
        </div>
      </section>

      <!-- ===================== PRINCIPLES ===================== -->
      <section class="home_page-section" data-region="principles">
        <div class="l_stack" data-gap="6">
          <header class="home_page-section_head">
            <div class="l_cluster" data-justify="between" data-gap="4" data-align="end">
              <h2 class="home_page-section_title"><span class="home_page-section_index">01</span>Principles</h2>
            </div>
          </header>

          <ul class="home_page-principle_list u_reset_list">
            <li class="home_page-principle">
              <div class="l_cluster" data-gap="4" data-align="start" data-nowrap>
                <span class="home_page-principle_index">01</span>
                <p class="home_page-principle_text">Less is more</p>
              </div>
            </li>
            <li class="home_page-principle">
              <div class="l_cluster" data-gap="4" data-align="start" data-nowrap>
                <span class="home_page-principle_index">02</span>
                <p class="home_page-principle_text">Consistency beats intensity</p>
              </div>
            </li>
            <li class="home_page-principle">
              <div class="l_cluster" data-gap="4" data-align="start" data-nowrap>
                <span class="home_page-principle_index">03</span>
                <p class="home_page-principle_text">Perfectionism kills startups</p>
              </div>
            </li>
            <li class="home_page-principle">
              <div class="l_cluster" data-gap="4" data-align="start" data-nowrap>
                <span class="home_page-principle_index">04</span>
                <p class="home_page-principle_text">Code is a liability. Keep it minimal</p>
              </div>
            </li>
            <li class="home_page-principle">
              <div class="l_cluster" data-gap="4" data-align="start" data-nowrap>
                <span class="home_page-principle_index">05</span>
                <p class="home_page-principle_text">
                  <a href="/blog/tech-debt-leverage">Tech debt is leverage</a> if the interest doesn't compound
                </p>
              </div>
            </li>
          </ul>
        </div>
      </section>

      <!-- ===================== SELECTED WORK (3 x 2) ===================== -->
      <section class="home_page-section" data-region="work">
        <div class="l_stack" data-gap="6">
          <header class="home_page-section_head">
            <div class="l_cluster" data-justify="between" data-gap="4" data-align="end">
              <h2 class="home_page-section_title"><span class="home_page-section_index">02</span>Selected Work</h2>
            </div>
          </header>

          <div class="l_grid" data-cols="3">
            <article class="work_card">
              <div class="l_cluster" data-justify="between" data-gap="2" data-align="start">
                <span class="work_card-index">01</span>
                <span class="work_card-status" data-variant="live">Live</span>
              </div>
              <div class="l_stack" data-gap="2">
                <h3 class="work_card-title">
                  <a class="work_card-link" target="_blank" rel="noopener noreferrer" href="https://lode.my"
                    >Lode Ecosystem</a
                  >
                </h3>
                <p class="work_card-desc">
                  A suite of apps for meticulous self-quantification. You are what you measure.
                </p>
              </div>
              <div class="l_spacer"></div>
              <div class="l_cluster" data-justify="between" data-gap="2">
                <span class="work_card-host u_truncate">lode.my</span>
                <span class="work_card-arrow" aria-hidden="true">↗</span>
              </div>
            </article>

            <article class="work_card">
              <div class="l_cluster" data-justify="between" data-gap="2" data-align="start">
                <span class="work_card-index">02</span>
                <span class="work_card-status">120K MAU</span>
              </div>
              <div class="l_stack" data-gap="2">
                <h3 class="work_card-title">
                  <a class="work_card-link" target="_blank" rel="noopener noreferrer" href="https://arcoin.net"
                    >ARCOIN</a
                  >
                </h3>
                <p class="work_card-desc">A geolocation-based AR metaverse. Peak scale: 120k MAU.</p>
              </div>
              <div class="l_spacer"></div>
              <div class="l_cluster" data-justify="between" data-gap="2">
                <span class="work_card-host u_truncate">arcoin.net</span>
                <span class="work_card-arrow" aria-hidden="true">↗</span>
              </div>
            </article>

            <article class="work_card">
              <div class="l_cluster" data-justify="between" data-gap="2" data-align="start">
                <span class="work_card-index">03</span>
                <span class="work_card-status">OSS</span>
              </div>
              <div class="l_stack" data-gap="2">
                <h3 class="work_card-title">
                  <a class="work_card-link" target="_blank" rel="noopener noreferrer" href="https://beamcss.org"
                    >BEAM CSS</a
                  >
                </h3>
                <p class="work_card-desc">
                  A strict, semantic, browser-native CSS architecture. The antidote to Atomic CSS and CSS-in-JS.
                </p>
              </div>
              <div class="l_spacer"></div>
              <div class="l_cluster" data-justify="between" data-gap="2">
                <span class="work_card-host u_truncate">beamcss.org</span>
                <span class="work_card-arrow" aria-hidden="true">↗</span>
              </div>
            </article>

            <article class="work_card">
              <div class="l_cluster" data-justify="between" data-gap="2" data-align="start">
                <span class="work_card-index">04</span>
                <span class="work_card-status">OSS · CLI</span>
              </div>
              <div class="l_stack" data-gap="2">
                <h3 class="work_card-title">
                  <a
                    class="work_card-link"
                    target="_blank"
                    rel="noopener noreferrer"
                    href="https://github.com/thefurdui/hap">hap</a
                  >
                </h3>
                <p class="work_card-desc">
                  A CLI tool to orchestrate parallel AI agents across different Git branches within the same repo.
                </p>
              </div>
              <div class="l_spacer"></div>
              <div class="l_cluster" data-justify="between" data-gap="2">
                <span class="work_card-host u_truncate">github.com/thefurdui/hap</span>
                <span class="work_card-arrow" aria-hidden="true">↗</span>
              </div>
            </article>

            <article class="work_card">
              <div class="l_cluster" data-justify="between" data-gap="2" data-align="start">
                <span class="work_card-index">05</span>
                <span class="work_card-status">OSS · CLI</span>
              </div>
              <div class="l_stack" data-gap="2">
                <h3 class="work_card-title">
                  <a
                    class="work_card-link"
                    target="_blank"
                    rel="noopener noreferrer"
                    href="https://github.com/thefurdui/wic">wic</a
                  >
                </h3>
                <p class="work_card-desc">
                  A CLI tool to compile wide-gamut (Display P3) web assets natively via headless Chromium.
                </p>
              </div>
              <div class="l_spacer"></div>
              <div class="l_cluster" data-justify="between" data-gap="2">
                <span class="work_card-host u_truncate">github.com/thefurdui/wic</span>
                <span class="work_card-arrow" aria-hidden="true">↗</span>
              </div>
            </article>

            <article class="work_card">
              <div class="l_cluster" data-justify="between" data-gap="2" data-align="start">
                <span class="work_card-index">06</span>
                <span class="work_card-status">Enterprise</span>
              </div>
              <div class="l_stack" data-gap="2">
                <h3 class="work_card-title">
                  <a
                    class="work_card-link"
                    target="_blank"
                    rel="noopener noreferrer"
                    href="https://www.saboit.de/references/audi-dpa">Audi DPA</a
                  >
                </h3>
                <p class="work_card-desc">
                  Enterprise IIoT infrastructure. A 3D assembly line and resource planner built for Audi and Volkswagen
                  factories.
                </p>
              </div>
              <div class="l_spacer"></div>
              <div class="l_cluster" data-justify="between" data-gap="2">
                <span class="work_card-host u_truncate">saboit.de</span>
                <span class="work_card-arrow" aria-hidden="true">↗</span>
              </div>
            </article>
          </div>
        </div>
      </section>

      <!-- ===================== BIO TIMELINE ===================== -->
      <section class="home_page-section" data-region="bio">
        <div class="l_stack" data-gap="6">
          <header class="home_page-section_head">
            <div class="l_cluster" data-justify="between" data-gap="4" data-align="end">
              <h2 class="home_page-section_title"><span class="home_page-section_index">03</span>Bio</h2>
            </div>
          </header>

          <ol class="home_page-bio_list u_reset_list">
            <li class="home_page-bio_entry">
              <time class="home_page-bio_year">2002</time>
              <p class="home_page-bio_desc">
                Born in Chișinău, Moldova <a
                  target="_blank"
                  rel="noopener noreferrer"
                  href="https://www.google.com/maps/place/Chi%C8%99in%C4%83u,+Moldova/@47.0131285,28.7739849,11.88z/data=!4m15!1m8!3m7!1s0x40c97c3628b769a1:0x258119acdf53accb!2sMoldova!3b1!8m2!3d47.411631!4d28.369885!16zL20vMDR3NHM!3m5!1s0x40c97c3628b769a1:0x37d1d6305749dd3c!8m2!3d47.0104529!4d28.8638102!16zL20vMGZuNzc?entry=ttu&g_ep=EgoyMDI2MDYwMy4xIKXMDSoASAFQAw%3D%3D"
                  >[where?]</a
                > (0yo)
              </p>
            </li>
            <li class="home_page-bio_entry">
              <time class="home_page-bio_year">2009</time>
              <p class="home_page-bio_desc">Started tinkering with Linux and custom Android ROMs (7yo)</p>
            </li>
            <li class="home_page-bio_entry">
              <time class="home_page-bio_year">2016</time>
              <p class="home_page-bio_desc">Started coding in Python (14yo)</p>
            </li>
            <li class="home_page-bio_entry">
              <time class="home_page-bio_year">2017</time>
              <p class="home_page-bio_desc">Built a Unity mobile game (15yo)</p>
            </li>
            <li class="home_page-bio_entry">
              <time class="home_page-bio_year">2018</time>
              <p class="home_page-bio_desc">
                Landed my first freelance gig. Implemented extreme Qubes OS opsec setup for a privacy-focused client
                (16yo)
              </p>
            </li>
            <li class="home_page-bio_entry">
              <time class="home_page-bio_year">2019</time>
              <p class="home_page-bio_desc">
                Secured a 6-month frontend contract with a governmental hosting provider in Kazakhstan (17yo)
              </p>
            </li>
            <li class="home_page-bio_entry">
              <time class="home_page-bio_year">2020</time>
              <p class="home_page-bio_desc">Moved to Prague the morning after I became a legal adult (18yo)</p>
            </li>
            <li class="home_page-bio_entry">
              <time class="home_page-bio_year">2021—23</time>
              <p class="home_page-bio_desc">
                Developed Audi & Volkswagen assembly line planner apps + other enterprise IIoT systems (18-21yo)
              </p>
            </li>
            <li class="home_page-bio_entry">
              <time class="home_page-bio_year">2024</time>
              <p class="home_page-bio_desc">
                Founded an <a target="_blank" rel="noopener noreferrer" href="https://arcoin.net/">AR/Crypto startup</a
                >. Raised $100k (21yo). Managed a team of 6
              </p>
            </li>
            <li class="home_page-bio_entry">
              <time class="home_page-bio_year">2025</time>
              <p class="home_page-bio_desc">
                Moved to Tashkent <a
                  target="_blank"
                  rel="noopener noreferrer"
                  href="https://www.google.com/maps/place/Tashkent,+Uzbekistan/@41.2827379,69.1145598,11z/data=!3m1!4b1!4m6!3m5!1s0x38ae8b0cc379e9c3:0xa5a9323b4aa5cb98!8m2!3d41.2982211!4d69.2385223!16zL20vMGZzbXk?entry=ttu&g_ep=EgoyMDI2MDYwMy4xIKXMDSoASAFQAw%3D%3D"
                  >[where?]</a
                > with my girlfriend. Closed the startup. <a
                  target="_blank"
                  rel="noopener noreferrer"
                  href="/arcoin-experience">Learned from pain</a
                > (22yo)
              </p>
            </li>
            <li class="home_page-bio_entry">
              <time class="home_page-bio_year">2026</time>
              <p class="home_page-bio_desc">
                Started using Neovim, btw. Optimizing my "system of being" with <a
                  target="_blank"
                  rel="noopener noreferrer"
                  href="/lode-101">Lode</a
                > (23yo)
              </p>
            </li>
            <li class="home_page-bio_entry" data-active="true">
              <time class="home_page-bio_year">Now</time>
              <p class="home_page-bio_desc">
                <i>typing</i><span class="home_page-bio_caret" aria-hidden="true"></span>
              </p>
            </li>
          </ol>
        </div>
      </section>

      <!-- ===================== CONTACT ===================== -->
      <section class="home_page-section" data-region="contact">
        <div class="l_stack" data-gap="6">
          <header class="home_page-section_head">
            <div class="l_cluster" data-justify="between" data-gap="4" data-align="end">
              <h2 class="home_page-section_title"><span class="home_page-section_index">04</span>Contact</h2>
            </div>
          </header>

          <ul class="home_page-contact_list u_reset_list">
            <li class="home_page-contact_row">
              <div class="l_cluster" data-justify="between" data-gap="4">
                <span class="home_page-contact_label">Email</span>
                <a class="home_page-contact_value" href="mailto:andrei@thefurdui.com">andrei@thefurdui.com</a>
              </div>
            </li>
            <li class="home_page-contact_row">
              <div class="l_cluster" data-justify="between" data-gap="4">
                <span class="home_page-contact_label">Calendar</span>
                <a
                  class="home_page-contact_value"
                  target="_blank"
                  rel="noopener noreferrer"
                  href="https://cal.com/thefurdui/15min">cal.com/thefurdui/15min</a
                >
              </div>
            </li>
            <li class="home_page-contact_row">
              <div class="l_cluster" data-justify="between" data-gap="4">
                <span class="home_page-contact_label">GitHub</span>
                <a
                  class="home_page-contact_value"
                  target="_blank"
                  rel="noopener noreferrer"
                  href="https://github.com/thefurdui">github.com/thefurdui</a
                >
              </div>
            </li>
            <li class="home_page-contact_row">
              <div class="l_cluster" data-justify="between" data-gap="4">
                <span class="home_page-contact_label">Twitter</span>
                <a
                  class="home_page-contact_value"
                  target="_blank"
                  rel="noopener noreferrer"
                  href="https://x.com/thefurdui">x.com/thefurdui</a
                >
              </div>
            </li>
          </ul>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
