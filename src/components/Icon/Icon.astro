---
interface Props extends astroHTML.JSX.SVGAttributes {
  /** Raw SVG string from './icon.svg?raw'` */
  content: string
}

const { content, ...attrs } = Astro.props

// Extract the inner content and source attributes from the raw SVG string
const openTagMatch = content.match(/^<svg([^>]*)>/s)
const sourceAttrsStr = openTagMatch?.[1] ?? ''
const innerHTML = content.replace(/^<svg[^>]*>/s, '').replace(/<\/svg>\s*$/, '')

// Parse source attributes into a Record
const sourceAttrs: Record<string, string> = {}
const attrRegex = /(\w[\w-]*)="([^"]*)"/g
let m: RegExpExecArray | null
while ((m = attrRegex.exec(sourceAttrsStr)) !== null) {
  // Skip xmlns - not needed for inline SVG
  if (m[1] !== 'xmlns') {
    sourceAttrs[m[1]] = m[2]
  }
}

const merged = { ...sourceAttrs, ...attrs }
---

<svg {...merged} set:html={innerHTML} />
